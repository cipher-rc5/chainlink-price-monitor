{
  "name": "chainlink-price-monitor",
  "version": "0.1.0",
  "type": "module",
  "description": "real-time Chainlink pricing data monitor with multi-chain support",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "type-check": "bun tsc --noEmit",
    "typecheck": "bun run type-check"
  },
  "dependencies": {
    "viem": "2.48.1",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/ws": "8.18.1",
    "typescript": "6.0.3"
  }
}
